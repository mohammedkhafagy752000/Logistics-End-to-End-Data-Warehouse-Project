--EXTRACT DATA FROM CSVs VIA BULK INSERT

BULK INSERT Customers
FROM 'D:\trainsql\logictis\customers.csv'
WITH (
    FORMAT = 'CSV',             
    FIRSTROW = 2,
    FIELDTERMINATOR = ',',
    ROWTERMINATOR = '0x0a',      
    TABLOCK                     
);

