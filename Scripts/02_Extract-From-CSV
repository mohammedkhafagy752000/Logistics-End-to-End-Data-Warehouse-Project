DROP TABLE IF EXISTS #Staging_DeliveryEvents;

-- 1. جدول staging 
CREATE TABLE #Staging_DeliveryEvents (
    event_id VARCHAR(20) PRIMARY KEY,
    load_id VARCHAR(20) NOT NULL,
    trip_id VARCHAR(20) NOT NULL,
    event_type VARCHAR(50) NOT NULL,
    facility_id VARCHAR(20),
    scheduled_datetime DATETIME NOT NULL,
    actual_datetime DATETIME NOT NULL,
    detention_minutes INT,
    on_time_flag VARCHAR(10) NOT NULL,
    location_city VARCHAR(50),
    location_state VARCHAR(50)
);

-- 2. تحميل CSV
BULK INSERT #Staging_DeliveryEvents
FROM 'D:\trainsql\logictis\delivery_events.csv'
WITH (
    FORMAT = 'CSV', 
    FIRSTROW = 2,
    FIELDTERMINATOR = ',',
    ROWTERMINATOR = '0x0a'
);


INSERT INTO DeliveryEvents (
    event_id,
    load_id,
    trip_id,
    event_type,
    facility_id,
    scheduled_datetime,
    actual_datetime,
    detention_minutes,
    on_time_flag,
    location_city,    
    location_state     
)
SELECT 
    event_id,
    load_id,
    trip_id,
    event_type,
    facility_id,
    scheduled_datetime,
    actual_datetime,
    detention_minutes,
    CASE 
        WHEN on_time_flag = 'true' THEN 1
        WHEN on_time_flag = 'false' THEN 0
        ELSE Null 
    END,
    location_city,    
    location_state     
FROM #Staging_DeliveryEvents;


