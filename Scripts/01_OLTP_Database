create DATABASE Logistics_OLTP;
USE Logistics_OLTP;

-- 1. DRIVERS
CREATE TABLE DRIVERS(
    driver_id VARCHAR(20) PRIMARY KEY,
    f_name VARCHAR(50),
    l_name VARCHAR(50),
    hire_date DATE,
    termination_date DATE,
    license_number VARCHAR(10),
    date_of_birth DATE,
    employment_status VARCHAR(20),
    cdl_class VARCHAR(3),
    years_experience INT
);

-- 2. TRUCKS
CREATE TABLE Trucks (
    truck_id VARCHAR(20) PRIMARY KEY,
    unit_number VARCHAR(50) NOT NULL,
    make VARCHAR(50) NOT NULL,
    model_year INT,
    vin VARCHAR(50) UNIQUE NOT NULL,
    acquisition_date DATE NOT NULL,
    acquisition_mileage INT,
    fuel_type VARCHAR(20),
    tank_capacity_gallons DECIMAL(6,2),
    status VARCHAR(20),
    home_terminal VARCHAR(100)
);

-- 3. TRAILERS
CREATE TABLE Trailers (
    trailer_id VARCHAR(20) PRIMARY KEY,
    trailer_number VARCHAR(50) NOT NULL,
    trailer_type VARCHAR(50),
    length_feet DECIMAL(5,2),
    model_year INT,
    vin VARCHAR(50) UNIQUE NOT NULL,
    acquisition_date DATE NOT NULL,
    status VARCHAR(20),
    current_location VARCHAR(100)
);

-- 4. CUSTOMERS
CREATE TABLE Customers (
    customer_id VARCHAR(20) PRIMARY KEY,
    customer_name VARCHAR(100) NOT NULL,
    customer_type VARCHAR(50),
    credit_terms_days INT,
    primary_freight_type VARCHAR(50),
    account_status VARCHAR(20),
    contract_start_date DATE,
    annual_revenue_potential DECIMAL(18,2)
);

-- 5. FACILITIES
CREATE TABLE Facilities (
    facility_id VARCHAR(20) PRIMARY KEY,
    facility_name VARCHAR(100) NOT NULL,
    facility_type VARCHAR(50),
    city VARCHAR(50),
    state VARCHAR(50),
    latitude DECIMAL(9,6),
    longitude DECIMAL(9,6),
    dock_doors INT,
    operating_hours VARCHAR(50)
);

-- 6. ROUTES
CREATE TABLE Routes (
    route_id VARCHAR(20) PRIMARY KEY,
    origin_city VARCHAR(50),
    origin_state VARCHAR(50),
    destination_city VARCHAR(50),
    destination_state VARCHAR(50),
    typical_distance_miles DECIMAL(10,2),
    base_rate_per_mile DECIMAL(10,2),
    fuel_surcharge_rate DECIMAL(5,2),
    typical_transit_days INT
);

-- 7. LOADS
CREATE TABLE Loads (
    load_id VARCHAR(20) PRIMARY KEY,
    customer_id VARCHAR(20),
    route_id VARCHAR(20),
    load_date DATE,
    load_type VARCHAR(50),
    weight_lbs DECIMAL(12,2),
    pieces INT,
    revenue DECIMAL(12,2),
    fuel_surcharge DECIMAL(10,2),
    accessorial_charges DECIMAL(10,2),
    load_status VARCHAR(20),
    booking_type VARCHAR(50),
    FOREIGN KEY (customer_id) REFERENCES Customers(customer_id),
    FOREIGN KEY (route_id)    REFERENCES Routes(route_id)
);

-- 8. TRIPS
CREATE TABLE Trips (
    trip_id VARCHAR(20) PRIMARY KEY,
    load_id VARCHAR(20),
    driver_id VARCHAR(20),
    truck_id VARCHAR(20),
    trailer_id VARCHAR(20),
    dispatch_date DATE,
    actual_distance_miles DECIMAL(10,2),
    actual_duration_hours DECIMAL(10,2),
    fuel_gallons_used DECIMAL(10,2),
    average_mpg DECIMAL(5,2),
    idle_time_hours DECIMAL(5,2),
    trip_status VARCHAR(20),
    FOREIGN KEY (load_id) REFERENCES Loads(load_id),
    FOREIGN KEY (driver_id) REFERENCES Drivers(driver_id),
    FOREIGN KEY (truck_id) REFERENCES Trucks(truck_id),
    FOREIGN KEY (trailer_id) REFERENCES Trailers(trailer_id)
);

-- 9. FUEL_PURCHASES
CREATE TABLE FuelPurchases (
    fuel_purchase_id VARCHAR(20) PRIMARY KEY,
    trip_id VARCHAR(20),
    truck_id VARCHAR(20),
    driver_id VARCHAR(20),
    purchase_date DATE,
    location_city VARCHAR(50),
    location_state VARCHAR(50),
    gallons DECIMAL(10,2),
    price_per_gallon DECIMAL(10,2),
    total_cost DECIMAL(12,2),
    fuel_card_number VARCHAR(50),
    FOREIGN KEY (trip_id) REFERENCES Trips(trip_id),
    FOREIGN KEY (truck_id) REFERENCES Trucks(truck_id),
    FOREIGN KEY (driver_id) REFERENCES Drivers(driver_id)
);

-- 10. MAINTENANCE_RECORDS
CREATE TABLE MaintenanceRecords (
    maintenance_id VARCHAR(20) PRIMARY KEY,
    truck_id VARCHAR(20),
    maintenance_date DATE,
    maintenance_type VARCHAR(50),
    odometer_reading DECIMAL(10,2),
    labor_hours DECIMAL(5,2),
    labor_cost DECIMAL(12,2),
    parts_cost DECIMAL(12,2),
    total_cost DECIMAL(12,2),
    facility_location VARCHAR(100),
    downtime_hours DECIMAL(5,2),
    service_description VARCHAR(255),
    FOREIGN KEY (truck_id) REFERENCES Trucks(truck_id)
);

-- 11. DELIVERY_EVENTS
CREATE TABLE DeliveryEvents (
    event_id VARCHAR(20) PRIMARY KEY,
    load_id VARCHAR(20) NOT NULL,
    trip_id VARCHAR(20) NOT NULL,
    event_type VARCHAR(50) NOT NULL,
    facility_id VARCHAR(20),
    scheduled_datetime DATETIME NOT NULL,
    actual_datetime DATETIME NOT NULL,
    detention_minutes INT,
    on_time_flag BIT NOT NULL,
    location_city VARCHAR(50),
    location_state VARCHAR(50),
    FOREIGN KEY (load_id) REFERENCES Loads(load_id),
    FOREIGN KEY (trip_id) REFERENCES Trips(trip_id),
    FOREIGN KEY (facility_id) REFERENCES Facilities(facility_id)
);

-- 12. SAFETY_INCIDENTS
CREATE TABLE SafetyIncidents (
    incident_id VARCHAR(20) PRIMARY KEY,
    trip_id VARCHAR(20),
    truck_id VARCHAR(20),
    driver_id VARCHAR(20),
    incident_date DATE,
    incident_type VARCHAR(50),
    location_city VARCHAR(50),
    location_state VARCHAR(50),
    at_fault_flag BIT,
    injury_flag BIT,
    vehicle_damage_cost DECIMAL(12,2),
    cargo_damage_cost DECIMAL(12,2),
    claim_amount DECIMAL(12,2),
    preventable_flag BIT,
    description VARCHAR(255),
    FOREIGN KEY (trip_id) REFERENCES Trips(trip_id),
    FOREIGN KEY (truck_id) REFERENCES Trucks(truck_id),
    FOREIGN KEY (driver_id) REFERENCES Drivers(driver_id)
);

-- 13. DRIVER_MONTHLY_METRICS
CREATE TABLE DriverMonthlyMetrics (
    driver_id VARCHAR(20),
    month DATE,
    trips_completed INT,
    total_miles DECIMAL(12,2),
    total_revenue DECIMAL(12,2),
    average_mpg DECIMAL(5,2),
    total_fuel_gallons DECIMAL(10,2),
    on_time_delivery_rate DECIMAL(5,2),
    average_idle_hours DECIMAL(5,2),
    PRIMARY KEY (driver_id, month),
    FOREIGN KEY (driver_id) REFERENCES Drivers(driver_id)
);

-- 14. TRUCK_UTILIZATION_METRICS
CREATE TABLE TruckUtilizationMetrics (
    truck_id VARCHAR(20),
    month DATE,
    trips_completed INT,
    total_miles DECIMAL(12,2),
    total_revenue DECIMAL(12,2),
    average_mpg DECIMAL(5,2),
    maintenance_events INT,
    maintenance_cost DECIMAL(12,2),
    downtime_hours DECIMAL(5,2),
    utilization_rate DECIMAL(5,2),
    PRIMARY KEY (truck_id, month),
    FOREIGN KEY (truck_id) REFERENCES Trucks(truck_id)
);
