-Data Validation & Cleaning
-------Trip table---------
--check 
SELECT  * 
from Trips t
left join DRIVERS D
ON T.driver_id = D.driver_id
where D.driver_id IS NULL;    --INVALID # NULL VALUE FOR  SOME DRIVERS

-- SOLUATION ADD Dummy Driver
INSERT INTO DRIVERS (driver_id, f_name, l_name, hire_date, employment_status)
VALUES ('DRV_UNKNOWN', 'Unknown', 'Driver', '2000-01-01', 'Unknown');
UPDATE Trips 
SET driver_id ='DRV_UNKNOWN'
WHERE driver_id IS NULL;  

UPDATE FuelPurchases
SET driver_id = 'DRV_UNKNOWN'
WHERE driver_id IS NULL;

UPDATE SafetyIncidents
SET driver_id = 'DRV_UNKNOWN'
WHERE driver_id IS NULL;
-- Problem solved

--check 
SELECT *
from Trips t
left join Trucks TR
ON T.truck_id =TR.truck_id
where TR.truck_id IS NULL;   --INVALID

-- SOLUATION ADD Dummy truck
INSERT INTO Trucks(truck_id,unit_number,make,vin,acquisition_date)
VALUES ('TR_UNKNOWN','UNK-000', 'Unknown','UNKNOWN-VIN', '2000-01-01');
UPDATE Trips 
SET truck_id ='TR_UNKNOWN'
WHERE truck_id IS NULL;  

UPDATE FuelPurchases
SET truck_id ='TR_UNKNOWN'
WHERE truck_id IS NULL;  

UPDATE SafetyIncidents
SET truck_id ='TR_UNKNOWN'
WHERE truck_id IS NULL; 

UPDATE MaintenanceRecords
SET truck_id ='TR_UNKNOWN'
WHERE truck_id IS NULL; 

-- Problem solved


