CREATE TABLE #STAGINGSAFTEY(
incident_id VARCHAR(20) PRIMARY KEY,
    trip_id VARCHAR(20),
    truck_id VARCHAR(20),
    driver_id VARCHAR(20),
    incident_date DATE,
    incident_type VARCHAR(50),
    location_city VARCHAR(50),
    location_state VARCHAR(50),
    at_fault_flag VARCHAR(10),
    injury_flag VARCHAR(10),
    vehicle_damage_cost DECIMAL(12,2),
    cargo_damage_cost DECIMAL(12,2),
    claim_amount DECIMAL(12,2),
    preventable_flag VARCHAR(10),
    description VARCHAR(255)
    );
    BULK INSERT #STAGINGSAFTEY 
    FROM 'D:\trainsql\logictis\safety_incidents.csv'
    WITH (
    FORMAT = 'CSV',             
    FIRSTROW = 2,
    FIELDTERMINATOR = ',',
    ROWTERMINATOR = '0x0a',      
    TABLOCK                     
    );

    INSERT INTO SafetyIncidents (
    incident_id ,
    trip_id ,
    truck_id,
    driver_id ,
    incident_date ,
    incident_type ,
    location_city ,
    location_state ,
    at_fault_flag ,
    injury_flag ,
    vehicle_damage_cost,
    cargo_damage_cost ,
    claim_amount ,
    preventable_flag ,
    description
    )
    SELECT 
    incident_id,
    trip_id ,
    truck_id,
    driver_id ,
    incident_date ,
    incident_type ,
    location_city ,
    location_state ,
    CASE
    WHEN at_fault_flag='True' then 1
    WHEN at_fault_flag='False' then 0
    else null
    END, 
    CASE
    WHEN injury_flag='True' then 1
    WHEN injury_flag='False' then 0
    else null
    END,
    vehicle_damage_cost,
    cargo_damage_cost ,
    claim_amount , 
    CASE
    WHEN preventable_flag='True' then 1
    WHEN preventable_flag='False' then 0
    else null
    END,
    description
    
    FROM #STAGINGSAFTEY;

